{
  "name": "sensehat-crypto-matrix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Display an 8x8 crypto correlation matrix on a Raspberry Pi Sense HAT.",
  "scripts": {
    "start": "node src/run-matrix.mjs --pi-url http://127.0.0.1:3000",
    "display": "node src/run-matrix.mjs",
    "display:simulate": "node src/run-matrix.mjs --simulate",
    "display:once": "node src/run-matrix.mjs --once"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "d3-color": "^3.1.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0"
  }
}
